{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(node --check:*)",
      "Bash(bash scripts/check-upstream.sh)",
      "Bash(curl -s https://raw.githubusercontent.com/ProtonMail/WebClients/*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
